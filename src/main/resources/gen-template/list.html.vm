<!DOCTYPE html>
<html>
<head>
    <title>${comments}</title>
	#set($header='<#include "/header.html">')
	#set($save='<#if shiro.hasPermission("'+${moduleName}+':'+${pathName}+':save")>')
	#set($update='<#if shiro.hasPermission("'+${moduleName}+':'+${pathName}+':update")>')
	#set($delete='<#if shiro.hasPermission("'+${moduleName}+':'+${pathName}+':delete")>')
	#set($exportExcel='<#if shiro.hasPermission("'+${moduleName}+':'+${pathName}+':exportExcel")>')
	#set($end='</#if>')
	$header
</head>
<body>
<div id="rrapp" v-cloak>
    <div v-show="showList">
        <div class="grid-btn">
			$save
            <a class="btn btn-primary" @click="add"><i class="fa fa-plus"></i>&nbsp;<@spring.message "system.info.add"/></a>
			$end
			$update
            <a class="btn btn-primary" @click="update"><i class="fa fa-pencil-square-o"></i>&nbsp;<@spring.message "system.info.update"/></a>
			$end
			$delete
            <a class="btn btn-primary" @click="del"><i class="fa fa-trash-o"></i>&nbsp;<@spring.message "system.info.delete"/></a>
			$end
			$exportExcel
            <a class="btn btn-primary" @click="exportExcel"><i class="fa fa-file-excel-o"></i>&nbsp;<@spring.message "system.info.export.excel"/></a>
			$end
        </div>
        <table id="jqGrid"></table>
        <div id="jqGridPager"></div>
    </div>

    <div v-show="!showList" class="panel panel-default">
        <div class="panel-heading">{{title}}</div>
        <form class="form-horizontal">
			#foreach($column in $columns)
				#if($column.columnName != $pk.columnName)
                    <div class="form-group">
                        <div class="col-sm-2 control-label">${column.comments}</div>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" v-model="${classname}.${column.firstLowercaseAttrName}" placeholder="${column.comments}"/>
                        </div>
                    </div>
				#end
			#end
            <div class="form-group">
                <div class="col-sm-2 control-label"></div>
                <input type="button" class="btn btn-primary" @click="saveOrUpdate" value="<@spring.message 'system.info.oks'/>"/>
                &nbsp;&nbsp;<input type="button" class="btn btn-warning" @click="reload" value='<@spring.message "system.info.return'/>"/>
            </div>
        </form>
    </div>
</div>

<script src="${request.contextPath}/statics/js/modules/${moduleName}/${pathName}.js?_${.now?long}"></script>
</body>
</html>